{
  "name": "sample",
  "version": "1.0.0",
  "description": "Rust 迁移样本预设",
  "Providers": [
    {
      "name": "openai",
      "api_base_url": "https://api.openai.com/v1/chat/completions",
      "api_key": "#{apiKey}",
      "models": ["gpt-5"]
    }
  ],
  "Router": {
    "default": "openai,gpt-5"
  },
  "schema": [
    {
      "id": "apiKey",
      "type": "password",
      "label": "OpenAI API Key",
      "required": true
    }
  ]
}
